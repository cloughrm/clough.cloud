---
layout: layouts/base
title: "Blog | clough.cloud"
---

<div class="blog-post-card">
	<h2>Blog Posts</h2>
	{% for post in collections.blog_posts %}
		<h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
		<p>{{ post.data.description }}</p>
	{% endfor %}
</div>

<div class="topics">
	<h2>Topics</h2>
	{% for topic in collections.topics %}
		<div><a href="/topics/{{topic | slugify}}">{{topic | slugify}}</a></div>
	{% endfor %}
</div>