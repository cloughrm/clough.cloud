<a class="tag" href="/topics/{{ tag | slugify }}">
	{% capture imgUrl %}{% topicImgSrc tag %}{% endcapture %}
	{% include "components/icon", img: imgUrl %}
	<span class="label">{{ tag }}</span>
	{% if count %}
		<span class="count">({{ count }})</span>
	{% endif %}
</a>

<style type="text/css">
	a.tag {
		color: inherit;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: .25rem;
		padding: 0 .5rem 0 .5rem;
	}

	a.tag .topic {
		display: flex;
		align-items: center;
		padding: .25rem;
	}

	a.tag:hover {
		background-color: var(--gray-200);
		border-radius: 5px;
	}

	a.tag .label {
		font-weight: 500;
	}

	a.tag .count {
		font-size: small;
	}

</style>