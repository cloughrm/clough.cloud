<div id="blog-post-list">
	{% for post in collections.blog_posts %}
		<h3>
			<a href="{{ post.url }}">{{ post.data.title }}</a>
			{# This is such a hack.... todo: fix #}
			<small>{{ post.date.toUTCString().split(' 00')[0] }}</small>
		</h3>
		<p>{{ post.data.description }}</p>
	{% endfor %}
</div>

<style type="text/css">
	#blog-post-list {
		flex: 1;
	}

	#blog-post-list h3 small {
		font-size: .75rem;
		font-weight: normal;
	}

	#blog-post-list p {
		margin-bottom: .75rem;
	}
</style>