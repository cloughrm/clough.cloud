<main>
	{% for post in collections.blog_posts reversed %}
		<article>
			<h3 class="post-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
			<div class="subheading">
				<span class="post-date">{{ post.date | toUTCString }}</span>
				{% for tag in post.data.tags %}
					{% if tag == "blog_posts" %}
						{% continue %}
					{% endif %}
					{% include "components/tag", tag: tag, count: false %}
				{% endfor %}
			</div>
			<p>{{ post.data.description }}</p>
		</article>
	{% endfor %}
</main>

<style type="text/css">
	main {
		flex: 1;
		padding: 1rem 0 1rem 0;
	}

	main .post-title a {
		color: inherit;
		text-decoration: none;
	}

	main .subheading {
		display: flex;
		flex-wrap: wrap;
	}

	main .post-date {
		font-style: italic;
	}

	main p {
		margin-bottom: .75rem;
	}
</style>