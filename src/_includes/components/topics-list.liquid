<aside>
	<h3>Filter By Topic</h3>
	<div class="topics-wrapper">
		{% for topicAndCount in collections.topics %}
			{% assign topic = topicAndCount[0] %}
			{% assign count = topicAndCount[1] %}
			<a class="topic" href="/topics/{{topic | slugify}}">
				<div class="icon"><img src="{% topicImgSrc topic %}"></div>
				<span class="label">{{topic}}</span>
				<span class="count"> ({{ count }})</span>
			</a>
		{% endfor %}
	</div>
</aside>

<style type="text/css">
	aside {
		flex: 0 0 14rem;
		padding: 1rem 0 1rem 0;
	}

	aside a {
		color: inherit;
		text-decoration: none;
	}

	aside .topics-wrapper {
		display: flex;
		flex-wrap: wrap;
		column-gap: 1rem;
	}

	aside .topic {
		display: flex;
		align-items: center;
		padding: .25rem;
	}

	aside .topic:hover {
		background-color: var(--gray-200);
		border-radius: 5px;
	}

	aside .topic .label {
		margin: 0 .25rem 0 .33rem;
		font-weight: 500;
	}

	aside .icon {
		height: 1rem;
		width: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	aside .icon img {
		max-width: 100%;
		max-height: 100%;
	}

	aside .topic .count {
		font-size: small;
	}

	/* Desktop Layout */
	@media (min-width: {{ meta.desktopMinWidth }}) {
		aside .topics-wrapper {
			display: block;
		}
		aside .topic {
			margin: .25rem 0 .25rem 0;
		}
	}
</style>
